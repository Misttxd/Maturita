# =============== #
#  Unity .gitignore #
# =============== #

# Library - auto-generated cache (largest folder)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Memory captures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Coverage data
/[Cc]overage[Rr]esults/

# ============ #
#  IDE / Editor #
# ============ #

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# ===== #
#  OS   #
# ===== #

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# =================== #
#  Unity specific      #
# =================== #

# Crashlytics
crashlytics-build.properties
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Compressed files (packages)
*.7z
*.gz
*.rar
*.tar
*.zip

# Plastic SCM
*.ignore
